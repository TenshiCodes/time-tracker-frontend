{
  "expo": {
    "name": "PBE Time App",
    "slug": "cleanApp",
    "version": "1.0.0",

    "icon": "./assets/images/pbe_small.png",

    "web": {
      "output": "static",
      "favicon": "./assets/images/pbe_favicon_2.png"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pacificblueengineering.timeapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "android": {
      "package": "com.tenshicodes.cleanapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/pbe_small.png",
        "resizeMode": "contain"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },

    "splash": {
      "image": "./assets/images/pbe_large.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./assets/images/pbe_large.png",
        "backgroundColor": "#000000"
      }
    },

    "extra": {
      "eas": {
        "projectId": "399ca44d-63ac-493c-a3fc-2addc45846fb"
      }
    },

    "updates": {
      "url": "https://u.expo.dev/399ca44d-63ac-493c-a3fc-2addc45846fb"
    },

    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
