{
  "expo": {
    "name": "PBE Time App",
    "slug": "cleanApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/pbe_small.png",
    "scheme": "cleanapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pacificblueengineering.timeapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tenshicodes.cleanapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/pbe_small.png",
        "resizeMode": "contain"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "splash": {
      "image": "./assets/images/pbe_large.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./assets/images/pbe_large.png",
        "backgroundColor": "#000000"
      }
    },
    "extra": {
      "eas": {
        "projectId": "399ca44d-63ac-493c-a3fc-2addc45846fb"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/399ca44d-63ac-493c-a3fc-2addc45846fb"
    }
  },
  "web": {
    "output": "static",
    "favicon": "./assets/images/pbe_fav.png"
  },
  "plugins": [
    "expo-router",
    "@react-native-community/datetimepicker",
    [
      "expo-splash-screen",
      {
        "image": "./assets/images/pbe_large.png",
        "imageWidth": 170,
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    ]
  ],
  "experiments": {
    "typedRoutes": true,
    "reactCompiler": true
  },
  "runtimeVersion": {
    "policy": "appVersion"
  },
  "updates": {
    "url": "https://u.expo.dev/399ca44d-63ac-493c-a3fc-2addc45846fb"
  },
  "extra": {
    "router": {},
    "eas": {
      "projectId": "399ca44d-63ac-493c-a3fc-2addc45846fb"
    }
  },
  "owner": "tenshicodes"
}
